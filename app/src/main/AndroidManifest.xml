<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Internet permission (kept) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:ignore="AdvertisingIdPolicy" /> <!-- Package visibility / handlers for VIEW https and Discord -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />

            <data android:scheme="https" />
        </intent>

        <package android:name="com.discord" />
    </queries>

    <application
        android:name=".ui.main.MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_label"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MagicRampageCompanion"
        tools:targetApi="33">

        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <activity
            android:name=".ui.items.Skins"
            android:exported="false" />
        <activity
            android:name=".ui.main.News"
            android:exported="false" />
        <activity
            android:name=".ui.enemies.EnemyDetail"
            android:exported="false" />
        <activity
            android:name=".ui.enemies.Enemies"
            android:exported="false" />
        <activity
            android:name=".ui.items.Items"
            android:exported="false" />
        <activity
            android:name=".ui.achievements.AchievementsPage"
            android:exported="false" />
        <activity
            android:name=".ui.levelviewer.LevelListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.levelviewer.LevelViewerActivity"
            android:exported="false" />
        <activity
            android:name=".ui.main.About"
            android:exported="false" />
        <activity
            android:name=".ui.survival.SurvivalModeSelection"
            android:exported="false" />
        <activity
            android:name=".ui.items.SkillPicker"
            android:exported="false" />
        <activity
            android:name=".ui.items.ItemSelection"
            android:exported="false" />
        <activity
            android:name=".ui.items.EquipmentTester"
            android:exported="false" />
        <activity
            android:name=".ui.items.ItemDetail"
            android:exported="false" />
        <activity
            android:name=".ui.dungeons.DungeonActivity"
            android:exported="false" />
        <activity
            android:name=".ui.chapters.Chapter1"
            android:exported="false"
            android:parentActivityName=".ui.chapters.ChapterSelection" />
        <activity
            android:name=".ui.chapters.Chapter2"
            android:exported="false" />
        <activity
            android:name=".ui.chapters.Chapter3"
            android:exported="false" />
        <activity
            android:name=".ui.chapters.Chapter4"
            android:exported="false" />
        <activity
            android:name=".ui.chapters.Chapter5"
            android:exported="false" />
        <activity
            android:name=".ui.chapters.ChapterSelection"
            android:exported="false"
            android:parentActivityName=".ui.main.MainActivity" />
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-9121645145370204~1734649227" />
    </application>

</manifest>
