<?xml version="1.0" encoding="utf-8"?>
<!-- "Create New Level" chooser body: two tappable option cards that echo the purple launcher card
     (same #0D1320 fill + editor-accent stroke + glow), replacing the plain text list. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="4dp">

    <!-- Empty level → blank canvas -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardEmptyLevel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="14dp"
        app:cardBackgroundColor="#0D1320"
        app:strokeColor="@color/menu_accent_editor"
        app:strokeWidth="2dp"
        app:rippleColor="@color/menu_accent_editor">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="76dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/new_level_card_glow"
            android:paddingStart="18dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_new_level"
                android:contentDescription="@string/new_level_option_blank" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_level_option_blank"
                    android:textColor="@android:color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/new_level_option_blank_sub"
                    android:textColor="#D7C7A9F0"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Edit an existing level → remix a stock level into an editable copy -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardExistingLevel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="14dp"
        app:cardBackgroundColor="#0D1320"
        app:strokeColor="@color/menu_accent_editor"
        app:strokeWidth="2dp"
        app:rippleColor="@color/menu_accent_editor">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="76dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/new_level_card_glow"
            android:paddingStart="18dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_duplicate"
                app:tint="#EDE6FF"
                android:contentDescription="@string/new_level_option_existing" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_level_option_existing"
                    android:textColor="@android:color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/new_level_option_existing_sub"
                    android:textColor="#D7C7A9F0"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
