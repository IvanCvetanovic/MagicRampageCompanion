<?xml version="1.0" encoding="utf-8"?>
<!-- layoutDirection=ltr: the editor is a spatial map tool; keep its chrome un-mirrored under RTL (Arabic). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="ltr">

    <xyz.magicrampagecompanion.ui.levelviewer.LevelRenderView
        android:id="@+id/levelRenderView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/levelTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/color_overlay_dark"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnLevelBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/cd_back" />

        <TextView
            android:id="@+id/levelViewerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="4dp"
            android:ellipsize="end"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btnShowSecrets"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="@string/cd_show_secrets" />

        <ImageButton
            android:id="@+id/btnToggleLogic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_view"
            android:contentDescription="@string/cd_toggle_logic" />

        <ImageButton
            android:id="@+id/btnToggleEdit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_edit"
            android:contentDescription="@string/cd_toggle_edit" />

        <ImageButton
            android:id="@+id/btnToggleSnap"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_grid_snap"
            android:contentDescription="@string/cd_toggle_snap"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnMarquee"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_crop"
            android:contentDescription="@string/cd_marquee"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnEntityList"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_agenda"
            android:contentDescription="@string/cd_entity_list"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnSave"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_save"
            android:contentDescription="@string/cd_save"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Editor bottom panel: property inspector (when an entity is selected) + tool row.
         Shown only in EDIT mode. -->
    <LinearLayout
        android:id="@+id/editorBottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/color_overlay_dark"
        android:visibility="gone">

        <!-- Shown instead of the inspector when a marquee selects a group of entities. -->
        <TextView
            android:id="@+id/groupSelectionInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textColor="@color/color_text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone" />

        <!-- Property inspector for the selected entity -->
        <LinearLayout
            android:id="@+id/editorInspector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/inspectorHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <ImageButton
                    android:id="@+id/btnDeselect"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:contentDescription="@string/cd_deselect" />
            </LinearLayout>

            <TextView
                android:id="@+id/inspectorMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_primary"
                android:alpha="0.6"
                android:textSize="11sp"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingBottom="6dp" />

            <Button
                android:id="@+id/btnEditEnemy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:text="@string/cd_edit_enemy"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/menu_accent_editor"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnEditGold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:text="@string/cd_set_gold"
                android:textColor="#000000"
                android:backgroundTint="@color/menu_accent_achievements"
                android:visibility="gone" />

            <!-- Row: X / Y / Z -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_x" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/stepXMinus" style="@style/EditorStepper"
                            android:text="@string/cd_decrease" android:contentDescription="@string/cd_decrease" />
                        <EditText android:id="@+id/inspectorX" android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                            android:textColor="@color/color_text_primary" android:textSize="14sp" android:gravity="center"
                            android:minHeight="40dp" android:importantForAutofill="no" />
                        <TextView android:id="@+id/stepXPlus" style="@style/EditorStepper"
                            android:text="@string/cd_increase" android:contentDescription="@string/cd_increase" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_y" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/stepYMinus" style="@style/EditorStepper"
                            android:text="@string/cd_decrease" android:contentDescription="@string/cd_decrease" />
                        <EditText android:id="@+id/inspectorY" android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                            android:textColor="@color/color_text_primary" android:textSize="14sp" android:gravity="center"
                            android:minHeight="40dp" android:importantForAutofill="no" />
                        <TextView android:id="@+id/stepYPlus" style="@style/EditorStepper"
                            android:text="@string/cd_increase" android:contentDescription="@string/cd_increase" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_z" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/stepZMinus" style="@style/EditorStepper"
                            android:text="@string/cd_decrease" android:contentDescription="@string/cd_decrease" />
                        <EditText android:id="@+id/inspectorZ" android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                            android:textColor="@color/color_text_primary" android:textSize="14sp" android:gravity="center"
                            android:minHeight="40dp" android:importantForAutofill="no" />
                        <TextView android:id="@+id/stepZPlus" style="@style/EditorStepper"
                            android:text="@string/cd_increase" android:contentDescription="@string/cd_increase" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Row: Scale X / Scale Y / Angle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_scale_x" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/stepSXMinus" style="@style/EditorStepper"
                            android:text="@string/cd_decrease" android:contentDescription="@string/cd_decrease" />
                        <EditText android:id="@+id/inspectorScaleX" android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                            android:textColor="@color/color_text_primary" android:textSize="14sp" android:gravity="center"
                            android:minHeight="40dp" android:importantForAutofill="no" />
                        <TextView android:id="@+id/stepSXPlus" style="@style/EditorStepper"
                            android:text="@string/cd_increase" android:contentDescription="@string/cd_increase" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_scale_y" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/stepSYMinus" style="@style/EditorStepper"
                            android:text="@string/cd_decrease" android:contentDescription="@string/cd_decrease" />
                        <EditText android:id="@+id/inspectorScaleY" android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                            android:textColor="@color/color_text_primary" android:textSize="14sp" android:gravity="center"
                            android:minHeight="40dp" android:importantForAutofill="no" />
                        <TextView android:id="@+id/stepSYPlus" style="@style/EditorStepper"
                            android:text="@string/cd_increase" android:contentDescription="@string/cd_increase" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_angle" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/stepAngMinus" style="@style/EditorStepper"
                            android:text="@string/cd_decrease" android:contentDescription="@string/cd_decrease" />
                        <EditText android:id="@+id/inspectorAngle" android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                            android:textColor="@color/color_text_primary" android:textSize="14sp" android:gravity="center"
                            android:minHeight="40dp" android:importantForAutofill="no" />
                        <TextView android:id="@+id/stepAngPlus" style="@style/EditorStepper"
                            android:text="@string/cd_increase" android:contentDescription="@string/cd_increase" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Row: Flip X / Flip Y -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">
                <CheckBox android:id="@+id/inspectorFlipX" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="@string/inspector_flip_x" android:textColor="@color/color_text_primary"
                    android:textSize="13sp" />
                <CheckBox android:id="@+id/inspectorFlipY" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="@string/inspector_flip_y" android:textColor="@color/color_text_primary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tool button row. Doubles as nav-bar spacer (padded for insets in the activity). -->
        <LinearLayout
            android:id="@+id/editorToolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/btnFitScreen"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_mylocation"
                android:contentDescription="@string/cd_fit_screen" />

            <ImageButton
                android:id="@+id/btnAddEntity"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add"
                android:contentDescription="@string/cd_add_entity" />

            <ImageButton
                android:id="@+id/btnDuplicateEntity"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_duplicate"
                android:contentDescription="@string/cd_duplicate_entity" />

            <ImageButton
                android:id="@+id/btnDeleteEntity"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_delete"
                android:contentDescription="@string/cd_delete_entity" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnUndo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_undo"
                android:contentDescription="@string/cd_undo" />

            <ImageButton
                android:id="@+id/btnRedo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_redo"
                android:contentDescription="@string/cd_redo" />

        </LinearLayout>

    </LinearLayout>

    <!-- Loading gate: shown while the level is parsed off the UI thread (ANR fix). clickable=true so
         it swallows taps on the controls underneath until the level is ready; system back still works. -->
    <FrameLayout
        android:id="@+id/levelLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_overlay_dark"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#FF00DCFF" />

    </FrameLayout>

</FrameLayout>
