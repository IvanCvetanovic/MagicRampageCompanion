<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <xyz.magicrampagecompanion.ui.levelviewer.LevelRenderView
        android:id="@+id/levelRenderView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/levelTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/color_overlay_dark"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnLevelBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/cd_back" />

        <TextView
            android:id="@+id/levelViewerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="4dp"
            android:ellipsize="end"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btnShowSecrets"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="@string/cd_show_secrets" />

        <ImageButton
            android:id="@+id/btnToggleLogic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_view"
            android:contentDescription="@string/cd_toggle_logic" />

        <ImageButton
            android:id="@+id/btnToggleEdit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/edit_icon"
            android:contentDescription="@string/cd_toggle_edit" />

        <ImageButton
            android:id="@+id/btnToggleSnap"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_grid_snap"
            android:contentDescription="@string/cd_toggle_snap"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Editor bottom panel: property inspector (when an entity is selected) + tool row.
         Shown only in EDIT mode. -->
    <LinearLayout
        android:id="@+id/editorBottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/color_overlay_dark"
        android:visibility="gone">

        <!-- Property inspector for the selected entity -->
        <LinearLayout
            android:id="@+id/editorInspector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/inspectorHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/inspectorMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_primary"
                android:alpha="0.6"
                android:textSize="11sp"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingBottom="6dp" />

            <!-- Row: X / Y / Z -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_x" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <EditText android:id="@+id/inspectorX" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                        android:textColor="@color/color_text_primary" android:textSize="14sp"
                        android:minHeight="40dp" android:importantForAutofill="no" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_y" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <EditText android:id="@+id/inspectorY" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                        android:textColor="@color/color_text_primary" android:textSize="14sp"
                        android:minHeight="40dp" android:importantForAutofill="no" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_z" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <EditText android:id="@+id/inspectorZ" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                        android:textColor="@color/color_text_primary" android:textSize="14sp"
                        android:minHeight="40dp" android:importantForAutofill="no" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row: Scale X / Scale Y / Angle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_scale_x" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <EditText android:id="@+id/inspectorScaleX" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                        android:textColor="@color/color_text_primary" android:textSize="14sp"
                        android:minHeight="40dp" android:importantForAutofill="no" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_scale_y" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <EditText android:id="@+id/inspectorScaleY" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                        android:textColor="@color/color_text_primary" android:textSize="14sp"
                        android:minHeight="40dp" android:importantForAutofill="no" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/inspector_angle" android:textColor="@color/color_text_primary"
                        android:alpha="0.6" android:textSize="11sp" />
                    <EditText android:id="@+id/inspectorAngle" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberSigned|numberDecimal"
                        android:textColor="@color/color_text_primary" android:textSize="14sp"
                        android:minHeight="40dp" android:importantForAutofill="no" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row: Flip X / Flip Y -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">
                <CheckBox android:id="@+id/inspectorFlipX" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="@string/inspector_flip_x" android:textColor="@color/color_text_primary"
                    android:textSize="13sp" />
                <CheckBox android:id="@+id/inspectorFlipY" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="@string/inspector_flip_y" android:textColor="@color/color_text_primary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tool button row (empty for now; future phases add buttons). Doubles as nav-bar spacer. -->
        <LinearLayout
            android:id="@+id/editorToolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical" />

    </LinearLayout>

</FrameLayout>
