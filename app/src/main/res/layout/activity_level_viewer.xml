<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <xyz.magicrampagecompanion.ui.levelviewer.LevelRenderView
        android:id="@+id/levelRenderView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/levelTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/color_overlay_dark"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnLevelBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/cd_back" />

        <TextView
            android:id="@+id/levelViewerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="4dp"
            android:ellipsize="end"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btnShowSecrets"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="@string/cd_show_secrets" />

        <ImageButton
            android:id="@+id/btnToggleLogic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_view"
            android:contentDescription="@string/cd_toggle_logic" />

        <ImageButton
            android:id="@+id/btnToggleEdit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/edit_icon"
            android:contentDescription="@string/cd_toggle_edit" />

    </LinearLayout>

    <!-- Editor toolbar: empty container for now (Phase 0); shown only in EDIT mode.
         Future phases add tool buttons here. -->
    <LinearLayout
        android:id="@+id/editorToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/color_overlay_dark"
        android:visibility="gone" />

</FrameLayout>
