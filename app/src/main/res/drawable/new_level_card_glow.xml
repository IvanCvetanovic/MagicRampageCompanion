<?xml version="1.0" encoding="utf-8"?>
<!-- Purple "magic" glow emanating from the icon side, fading into the card's dark navy.
     The card clips this to its 14dp rounded corners, so no corners are needed here. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="75%p"
        android:centerX="0.16"
        android:centerY="0.5"
        android:startColor="#3A2A66"
        android:endColor="#120E22" />
</shape>
